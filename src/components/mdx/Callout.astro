---
/**
 * Callout - A styled box for questions, notes, warnings, or highlighted content
 *
 * Usage in MDX:
 * <Callout type="question">
 *   How can we optimize learning while keeping learners engaged?
 * </Callout>
 */

interface Props {
  /** The type of callout: question, note, warning, tip */
  type?: 'question' | 'note' | 'warning' | 'tip';
}

const { type = 'note' } = Astro.props;

const typeStyles = {
  question: {
    bg: 'bg-secondary-50',
    border: 'border-secondary-300',
    icon: '?',
    iconBg: 'bg-secondary-100',
    iconText: 'text-secondary-700',
  },
  note: {
    bg: 'bg-primary-50',
    border: 'border-primary-300',
    icon: 'i',
    iconBg: 'bg-primary-100',
    iconText: 'text-primary-700',
  },
  warning: {
    bg: 'bg-amber-50',
    border: 'border-amber-300',
    icon: '!',
    iconBg: 'bg-amber-100',
    iconText: 'text-amber-700',
  },
  tip: {
    bg: 'bg-green-50',
    border: 'border-green-300',
    icon: '*',
    iconBg: 'bg-green-100',
    iconText: 'text-green-700',
  },
};

const styles = typeStyles[type];
---

<div
  class={`callout flex items-stretch gap-4 md:gap-8 my-6 font-semibold ${styles.border} border-l-4 ${styles.bg} -mx-4 lg:mx-0 px-4 lg:px-6 py-4 shadow-md rounded-r-md`}
>
  <div class="callout-content flex-1">
    <slot />
  </div>
  <div
    class={`callout-icon ${styles.iconBg} ${styles.iconText} rounded-l-full pl-2 pr-2 md:pl-3 md:pr-6 text-4xl md:text-5xl flex items-center justify-center shadow-md`}
  >
    {styles.icon}
  </div>
</div>

<style>
  .callout-content :global(p) {
    margin: 0;
  }
</style>
