---
/**
 * ProjectHero - Renders the hero section from project frontmatter
 *
 * This component takes structured hero data from frontmatter and renders
 * a consistent hero section. For projects requiring custom hero layouts
 * (like carousels), the MDX can override this with custom content.
 */

import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  hero: {
    headline: string;
    subheading?: string;
    featuredImage?: ImageMetadata;
    featuredImageAlt?: string;
  };
}

const { hero } = Astro.props;
---

<div
  class="hero-container mt-8 mb-6 items-center flex flex-col md:flex-row max-w-screen-xl mx-auto"
>
  <div
    class="flex flex-col px-4 justify-center text-center md:text-center md:items-center flex-1"
  >
    <h1
      class="text-4xl md:text-5xl xl:text-6xl mb-6 text-foreground font-black"
      set:html={hero.headline}
    />
    {
      hero.subheading && (
        <h2
          class="text-xl/7.5 xl:text-2xl/9 mb-4 text-foreground tracking-normal md:text-center"
          set:html={hero.subheading}
        />
      )
    }
  </div>
  {
    hero.featuredImage && (
      <div class="w-full max-w-md xl:max-w-xl md:mx-auto px-4 py-4">
        <Image
          src={hero.featuredImage}
          alt={hero.featuredImageAlt || ''}
          class="rounded-lg shadow-lg"
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 100vw, 600px"
        />
      </div>
    )
  }
</div>
