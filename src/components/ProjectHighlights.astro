---
/**
 * ProjectHighlights - Renders the 3-column highlights section from frontmatter
 *
 * Takes structured highlights data and renders using the existing Highlight component
 * styling, with icons resolved via the IconRegistry.
 */

import IconRegistry from './IconRegistry.astro';

interface HighlightItem {
  title: string;
  description: string;
  icon?: string;
}

interface Props {
  highlights: HighlightItem[];
}

const { highlights } = Astro.props;
---

<div class="block pt-12 pb-14 lg:pb-18 px-4 shadow-md bg-card">
  <h3
    class="tracking-narrow text-center mb-12 lg:text-4xl lg:mb-16 text-4xl tracking-tight font-extrabold text-neutral-900"
  >
    Project Highlights
  </h3>

  <div
    class="grid grid-flow-row auto-rows-fr sm:grid-cols-1 lg:grid-cols-3 gap-x-6 xl:gap-x-10 gap-y-12 items-stretch justify-items-stretch max-w-screen-xl mx-auto"
  >
    {
      highlights.map((highlight) => (
        <div class="flex flex-col w-full h-full mb-2 px-4 pt-2 pb-2 border-4 rounded-lg border-accent-800 bg-neutral-100 shadow-lg">
          {highlight.icon && (
            <div class="icon-container">
              <IconRegistry
                name={highlight.icon}
                class="w-12 h-12 mx-auto -mt-8 mb-2"
                style="--icon-field-color: var(--color-primary-800); --icon-subject-color: var(--color-accent-300);"
              />
            </div>
          )}
          <div class="text-center">
            <h2 class="text-2xl font-extrabold leading-tight text-primary-700">
              {highlight.title}
            </h2>
            <div class="text-sm/5 font-medium mt-2 mx-auto">
              {highlight.description}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>
